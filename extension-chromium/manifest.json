{
  "manifest_version": 3,
  "name": "URL Lookalike Blocker",
  "version": "1.3.0",
  "description": "Blocks and warns when a domain uses characters from scripts (languages) outside your locale setting — protection against IDN homograph attacks.",
  "icons": {
    "32": "icon.svg",
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "webNavigation",
    "storage",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "warning.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "URL Lookalike Blocker Options",
    "default_icon": "icon.svg"
  },
  "options_page": "options.html"
}
