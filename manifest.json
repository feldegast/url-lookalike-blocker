{
  "manifest_version": 3,
  "name": "URL Lookalike Blocker",
  "version": "1.0",
  "icons": {
    "32": "icon.png",
    "48": "icon.png",
    "96": "icon.png"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.js", "icon.svg", "icon.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "scripts": ["unicode-scripts.js", "background.js"]
  },
  "action": {
    "default_popup": "options.html",
    "default_title": "URL Lookalike Blocker Options"
  },
  "options_page": "options.html"
}