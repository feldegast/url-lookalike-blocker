{
  "manifest_version": 3,
  "name": "URL Lookalike Blocker",
  "version": "1.2.1",
  "description": "Blocks and warns when a domain uses characters from scripts (languages) outside your locale setting — protection against IDN homograph attacks.",
  "browser_specific_settings": {
    "gecko": {
      "id": "url-lookalike-blocker@feldegast.github.io",
      "strict_min_version": "126.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "140.0"
    }
  },
  "icons": {
    "32": "icon.svg",
    "48": "icon.svg",
    "96": "icon.svg",
    "128": "icon.svg"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "menus",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "warning.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "scripts": ["unicode-scripts.js", "background.js", "background-dev.js"]
  },
  "action": {
    "default_title": "URL Lookalike Blocker Options",
    "default_icon": "icon.svg"
  },
  "options_page": "options.html"
}